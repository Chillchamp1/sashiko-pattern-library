rules_version = '2';

// Security rules for the Sashiko Pattern Library Firestore.
//
// The app ships a public (by-design) Firebase web config and uses ANONYMOUS auth,
// so anyone can get a session. These rules ensure that even so:
//   - the gallery stays publicly readable,
//   - nobody can WIPE the collection (hard delete is off; the app tombstones),
//   - a pattern can only be edited/tombstoned by its creator (or an admin),
//   - only well-formed, size-bounded documents can be written.
//
// DEPLOY: Firebase Console -> Firestore Database -> Rules -> paste -> Publish,
//         or: firebase deploy --only firestore:rules
// ALSO REQUIRED: Firebase Console -> Authentication -> Sign-in method -> enable "Anonymous".

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist: anonymous uids allowed to edit/tombstone ANY pattern.
    // On the live site, open the browser console and run  sashikoMyUid()  then
    // paste the uid below. Anonymous uids are per-browser; add each device you admin from.
    function isAdmin() {
      return request.auth != null
          && request.auth.uid in ['PASTE_YOUR_ADMIN_UID_HERE'];
    }

    // Basic shape/size validation: keeps junk and oversized blobs out.
    function isValidPattern(d) {
      return d.type == 'exp'
          && d.id is string && d.id.size() < 200
          && d.keys().size() < 80
          && (!('name' in d) || (d.name is string && d.name.size() < 200))
          && (!('lines' in d) || (d.lines is list && d.lines.size() <= 5000));
    }

    match /patterns/{id} {
      allow read: if true;

      allow create: if request.auth != null
                    && isValidPattern(request.resource.data)
                    && request.resource.data.creatorId == request.auth.uid;

      allow update: if request.auth != null
                    && isValidPattern(request.resource.data)
                    && (resource.data.creatorId == request.auth.uid || isAdmin());

      // Hard delete is disabled. The app sets deleted:true (a tombstone write),
      // so the collection can never be wiped.
      allow delete: if false;

      // Community stitching-order profiles (currently disabled in the app).
      match /profiles/{pid} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}

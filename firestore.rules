rules_version = '2';

// Security rules for the Sashiko Pattern Library Firestore.
//
// Model:
//   - The GALLERY (published patterns) is the protected asset: only the admin can
//     publish, or edit/delete anything that is published.
//   - The SANDBOX (unpublished patterns) is open: any signed-in visitor (anonymous
//     is fine) can add and edit/remove unpublished patterns. Not airtight by design.
//   - Hard delete is disabled everywhere; the app tombstones (sets deleted:true), so
//     the collection can never be wiped.
//
// SETUP:
//   1. Firebase Console -> Authentication -> Sign-in method:
//        enable "Anonymous"  AND  "Google".
//   2. Put your Google address in isAdmin() below (replace the placeholder).
//      (Rules are server-side/private, so the email is NOT exposed to visitors.)
//   3. Deploy: Console -> Firestore Database -> Rules -> paste -> Publish,
//      or:  firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = signed in with a real Google account whose verified email is listed here.
    // Anonymous sessions have no email, so they are never admin.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email in ['PASTE_YOUR_GOOGLE_EMAIL'];
    }

    function isValidPattern(d) {
      return d.type == 'exp'
          && d.id is string && d.id.size() < 200
          && d.keys().size() < 80
          && (!('name' in d) || (d.name is string && d.name.size() < 200))
          && (!('lines' in d) || (d.lines is list && d.lines.size() <= 5000));
    }

    function unpublished(d) {
      return d.get('published', false) == false;
    }

    match /patterns/{id} {
      allow read: if true;                                   // gallery + sandbox public

      // Create: any signed-in visitor may add an UNPUBLISHED (sandbox) pattern.
      // Creating something already published requires admin.
      allow create: if request.auth != null
                    && isValidPattern(request.resource.data)
                    && (unpublished(request.resource.data) || isAdmin());

      // Update: admin can change anything. Everyone else may only touch a pattern that
      // is unpublished AND stays unpublished -> so nobody but admin can publish to the
      // gallery or modify a gallery pattern. (Tombstone-delete is an update too.)
      allow update: if isAdmin()
                    || (request.auth != null
                        && isValidPattern(request.resource.data)
                        && unpublished(resource.data)
                        && unpublished(request.resource.data));

      // No hard deletes - the app uses tombstones (deleted:true).
      allow delete: if false;

      // Community stitching-order profiles (currently disabled in the app).
      match /profiles/{pid} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Per-pattern comments (handle + text). Public read; any signed-in visitor
      // (anonymous is fine) may post. Text only — no photos.
      match /comments/{cid} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 500
                      && request.resource.data.handle is string
                      && request.resource.data.handle.size() <= 40;
        allow update, delete: if isAdmin();
      }
    }
  }
}
